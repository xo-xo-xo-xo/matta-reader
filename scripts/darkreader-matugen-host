#!/usr/bin/env python3
import json
import os
import struct
import sys
import threading

MATUGEN_FILE = os.path.expanduser("~/.config/matugen/output/darkreader.json")
POLL_INTERVAL = 2.0


def send_message(message):
    data = json.dumps(message).encode("utf-8")
    try:
        sys.stdout.buffer.write(struct.pack("<I", len(data)))
        sys.stdout.buffer.write(data)
        sys.stdout.buffer.flush()
    except (BrokenPipeError, OSError):
        sys.exit(0)


def read_message():
    raw_length = sys.stdin.buffer.read(4)
    if len(raw_length) < 4:
        return None
    length = struct.unpack("<I", raw_length)[0]
    if length == 0:
        return None
    data = sys.stdin.buffer.read(length)
    if len(data) < length:
        return None
    try:
        return json.loads(data.decode("utf-8"))
    except (json.JSONDecodeError, UnicodeDecodeError):
        return None


def read_theme_file():
    try:
        with open(MATUGEN_FILE, "r") as f:
            return json.load(f)
    except FileNotFoundError:
        return None
    except (json.JSONDecodeError, OSError) as e:
        send_message({"type": "error", "message": f"Cannot parse {MATUGEN_FILE}: {e}"})
        return None


def get_file_mtime():
    try:
        return os.stat(MATUGEN_FILE).st_mtime
    except OSError:
        return 0


def file_watcher(stop_event, ready_event):
    last_mtime = 0
    data = read_theme_file()
    if data:
        send_message({"type": "matugen-update", "settings": data})
        last_mtime = get_file_mtime()
    else:
        send_message({"type": "error", "message": f"Cannot read {MATUGEN_FILE}. Run matugen first."})
    ready_event.set()
    while not stop_event.is_set():
        mtime = get_file_mtime()
        if mtime != last_mtime:
            last_mtime = mtime
            data = read_theme_file()
            if data:
                send_message({"type": "matugen-update", "settings": data})
        stop_event.wait(POLL_INTERVAL)


def handle_extension_message(msg):
    if msg is None:
        return False
    if msg.get("type") == "refresh":
        data = read_theme_file()
        if data:
            send_message({"type": "matugen-update", "settings": data})
    return True


def main():
    stop_event = threading.Event()
    ready_event = threading.Event()
    watcher = threading.Thread(target=file_watcher, args=(stop_event, ready_event), daemon=True)
    watcher.start()
    try:
        while True:
            msg = read_message()
            if msg is None:
                break
            handle_extension_message(msg)
    except Exception:
        pass
    finally:
        stop_event.set()


if __name__ == "__main__":
    main()
