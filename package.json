{
  "name": "matta-reader",
  "version": "4.9.130",
  "description": "Dark mode for every website, with matugen integration",
  "scripts": {
    "build": "node --max-old-space-size=3072 tasks/cli.js build --release --firefox",
    "debug": "node --max-old-space-size=3072 tasks/cli.js build --debug --firefox",
    "lint": "eslint -- src/**/*.ts src/**/*.tsx tasks/**/*.js eslint.config.js index.d.ts"
  },
  "type": "module",
  "license": "MIT",
  "keywords": [
    "dark-theme",
    "dark-mode",
    "night-mode"
  ],
  "dependencies": {
    "malevic": "0.20.2"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/chrome": "0.1.42",
    "@types/eslint": "9.6.1",
    "@types/node": "25.9.1",
    "chokidar": "5.0.0",
    "eslint-plugin-compat": "7.0.2",
    "eslint-plugin-import": "2.32.0",
    "globals": "17.6.0",
    "globby": "16.2.0",
    "less": "4.6.4",
    "prettier": "3.8.3",
    "rollup": "4.60.4",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "ws": "^8.21.0",
    "yazl": "3.3.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.4"
  }
}
